{
  "hooks": {
    "PreToolUse": [
      {
        "matcher": "Bash",
        "hooks": [
          {
            "type": "command",
            "command": "node .claude/hooks/pre-commit-check.js"
          }
        ]
      }
    ],
    "PostToolUse": [
      {
        "matcher": "Edit|Write",
        "hooks": [
          {
            "type": "command",
            "command": "node .claude/hooks/post-edit-lint.js"
          },
          {
            "type": "command",
            "command": "node .claude/hooks/console-log-check.js"
          }
        ]
      }
    ]
  },
  "permissions": {
    "allow": [
      "Bash(grep:*)",
      "Bash(sed:*)",
      "Bash(cat:*)",
      "Bash(head:*)",
      "Bash(tail:*)",
      "Bash(find:*)",
      "Bash(wc:*)",
      "Bash(sort:*)",
      "Bash(awk:*)",
      "Bash(diff:*)",
      "Bash(which:*)",
      "Bash(ls:*)",
      "Bash(echo:*)",
      "Bash(mkdir:*)",
      "Bash(cp:*)",
      "Bash(mv:*)",
      "Bash(touch:*)",
      "Bash(dirname:*)",
      "Bash(basename:*)",
      "Bash(realpath:*)",
      "Bash(xargs:*)",
      "Bash(tr:*)",
      "Bash(cut:*)",
      "Bash(uniq:*)",
      "Bash(tee:*)",
      "Bash(jq:*)",
      "Bash(node:*)",
      "Bash(docker compose:*)",
      "Bash(git status:*)",
      "Bash(git log:*)",
      "Bash(git diff:*)",
      "Bash(git show:*)",
      "Bash(git blame:*)",
      "Bash(git rev-parse:*)",
      "Bash(git remote:*)",
      "Bash(git fetch:*)",
      "Bash(npm run:*)",
      "Bash(npm test:*)",
      "Bash(npm install:*)",
      "Bash(npx vitest:*)",
      "Bash(npx tsc:*)",
      "Bash(npx tsx:*)",
      "Bash(npx eslint:*)",
      "WebSearch",
      "Bash(gh search:*)",
      "Bash(gh api:*)",
      "WebFetch(domain:docs.anthropic.com)",
      "WebFetch(domain:aws.amazon.com)",
      "WebFetch(domain:www.metaltoad.com)",
      "WebFetch(domain:github.com)",
      "WebFetch(domain:www.braintrust.dev)",
      "WebFetch(domain:www.confident-ai.com)",
      "WebFetch(domain:dev.to)",
      "WebFetch(domain:hamel.dev)",
      "WebFetch(domain:arxiv.org)",
      "WebFetch(domain:www.getmaxim.ai)",
      "WebFetch(domain:www.langchain.com)"
    ]
  }
}
